<section id="registerView" class="auth-form-wrap d-none" aria-labelledby="registerTitle">
    <div class="mobile-brand">
        <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z"/><path d="m4.5 7.8 7.5 4.3 7.5-4.3M12 12.1V21"/></svg>
        </span>
        <span>ProductHub</span>
    </div>
    <div class="auth-card">
        <div class="auth-card-heading">
            <p class="eyebrow">Get started</p>
            <h2 id="registerTitle">Create your account</h2>
            <p>Start managing your product catalog today</p>
        </div>
        <form id="registerForm" novalidate>
            <div class="form-field">
                <label for="registerEmail" class="form-label">Email address</label>
                <input id="registerEmail" name="email" type="email" class="form-control" autocomplete="email" placeholder="you@example.com" aria-describedby="registerEmailError">
                <p id="registerEmailError" class="field-error" role="alert"></p>
            </div>
            <div class="form-field">
                <label for="registerPassword" class="form-label">Password</label>
                <div class="password-wrap">
                    <input id="registerPassword" name="password" type="password" class="form-control" autocomplete="new-password" placeholder="Minimum 8 characters" aria-describedby="registerPasswordError">
                    <button class="password-toggle" type="button" data-toggle-password="registerPassword" aria-label="Show password">
                        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg>
                    </button>
                </div>
                <p id="registerPasswordError" class="field-error" role="alert"></p>
            </div>
            <div class="form-field">
                <label for="confirmPassword" class="form-label">Confirm password</label>
                <div class="password-wrap">
                    <input id="confirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="Repeat your password" aria-describedby="confirmPasswordError">
                    <button class="password-toggle" type="button" data-toggle-password="confirmPassword" aria-label="Show password">
                        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg>
                    </button>
                </div>
                <p id="confirmPasswordError" class="field-error" role="alert"></p>
            </div>
            <p id="registerFormError" class="form-alert" role="alert"></p>
            <button id="registerButton" class="btn btn-primary auth-submit" type="submit">
                <span class="button-label">Create Account</span>
                <span class="spinner-border spinner-border-sm d-none" aria-hidden="true"></span>
            </button>
        </form>
        <p class="auth-switch">Already have an account? <button id="showLoginButton" class="link-button" type="button">Sign in</button></p>
    </div>
</section>
