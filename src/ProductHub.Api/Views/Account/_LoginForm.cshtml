<section id="loginView" class="auth-form-wrap" aria-labelledby="loginTitle">
    <div class="mobile-brand">
        <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z"/><path d="m4.5 7.8 7.5 4.3 7.5-4.3M12 12.1V21"/></svg>
        </span>
        <span>ProductHub</span>
    </div>
    <div class="auth-card">
        <div class="auth-card-heading">
            <p class="eyebrow">Welcome</p>
            <h2 id="loginTitle">Welcome back</h2>
            <p>Sign in to continue to your account</p>
        </div>
        <form id="loginForm" novalidate>
            <div class="form-field">
                <label for="loginEmail" class="form-label">Email address</label>
                <input id="loginEmail" name="email" type="email" class="form-control" autocomplete="email" placeholder="you@example.com" aria-describedby="loginEmailError">
                <p id="loginEmailError" class="field-error" role="alert"></p>
            </div>
            <div class="form-field">
                <label for="loginPassword" class="form-label">Password</label>
                <div class="password-wrap">
                    <input id="loginPassword" name="password" type="password" class="form-control" autocomplete="current-password" placeholder="Enter your password" aria-describedby="loginPasswordError">
                    <button class="password-toggle" type="button" data-toggle-password="loginPassword" aria-label="Show password">
                        <svg class="eye-open" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg>
                    </button>
                </div>
                <p id="loginPasswordError" class="field-error" role="alert"></p>
            </div>
            <div class="form-check auth-check">
                <input id="rememberMe" class="form-check-input" type="checkbox">
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>
            <p id="loginFormError" class="form-alert" role="alert"></p>
            <button id="loginButton" class="btn btn-primary auth-submit" type="submit">
                <span class="button-label">Sign In</span>
                <span class="spinner-border spinner-border-sm d-none" aria-hidden="true"></span>
            </button>
        </form>
        <p class="auth-switch">Don't have an account? <button id="showRegisterButton" class="link-button" type="button">Create account</button></p>
    </div>
</section>
