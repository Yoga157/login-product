@{
    ViewData["Title"] = "Product Management";
}

<div id="authShell" class="auth-shell">
    <partial name="~/Views/Account/_AuthBrand.cshtml" />
    <main class="auth-panel">
        <partial name="~/Views/Account/_LoginForm.cshtml" />
        <partial name="~/Views/Account/_RegisterForm.cshtml" />
    </main>
</div>

<div id="appShell" class="app-shell d-none">
    <partial name="~/Views/Shared/_Sidebar.cshtml" />
    <div id="sidebarOverlay" class="sidebar-overlay" aria-hidden="true"></div>
    <div class="app-workspace">
        <partial name="~/Views/Shared/_Topbar.cshtml" />
        <main class="main-content" id="mainContent">
            <section class="page-heading">
                <div>
                    <p class="eyebrow mb-2">Catalog</p>
                    <h1>Products</h1>
                    <p class="page-subtitle">Manage your product catalog</p>
                </div>
                <button id="addProductButton" class="btn btn-primary btn-add-product" type="button">
                    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                    Add Product
                </button>
            </section>

            <section class="filter-card" aria-labelledby="filterHeading">
                <div class="filter-title-row">
                    <div>
                        <h2 id="filterHeading">Search &amp; filters</h2>
                        <p>Find products by name or price range.</p>
                    </div>
                    <button id="clearFiltersButton" class="btn btn-link btn-clear" type="button">Clear filters</button>
                </div>
                <form id="filterForm" class="filter-grid" novalidate>
                    <div class="search-control">
                        <label for="searchName" class="form-label">Product name</label>
                        <div class="input-icon-wrap">
                            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
                            <input id="searchName" class="form-control" placeholder="Search by product name" maxlength="150" autocomplete="off">
                        </div>
                    </div>
                    <div>
                        <label for="minPrice" class="form-label">Minimum price</label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input id="minPrice" type="number" class="form-control" min="0" step="1" placeholder="0">
                        </div>
                    </div>
                    <div>
                        <label for="maxPrice" class="form-label">Maximum price</label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input id="maxPrice" type="number" class="form-control" min="0" step="1" placeholder="No limit">
                        </div>
                    </div>
                    <button class="btn btn-outline-primary btn-apply" type="submit">Apply filter</button>
                    <p id="filterError" class="field-error filter-error" role="alert"></p>
                </form>
            </section>

            <section class="product-card" aria-labelledby="productTableHeading">
                <div class="product-card-header">
                    <div>
                        <h2 id="productTableHeading">Product catalog</h2>
                        <p id="productCount">Loading products...</p>
                    </div>
                </div>
                <div id="productContent" class="product-content" aria-live="polite"></div>
            </section>
        </main>
    </div>
</div>

<partial name="~/Views/Products/_ProductForm.cshtml" />
<partial name="~/Views/Products/_DeleteProductModal.cshtml" />
<partial name="~/Views/Products/_DiscardChangesModal.cshtml" />
<partial name="~/Views/Shared/_Toast.cshtml" />
